USE_LOCAL_MODEL=false

# Cohere settings (used when USE_LOCAL_MODEL=false)
COHERE_API_KEY=your_cohere_api_key
COHERE_EMBED_MODEL=embed-v4.0
# 256, 512, 1024, or 1536 — only applies to embed-v4.x
COHERE_EMBED_OUTPUT_DIMENSION=1024
# auto = try /v2/embed then /v1/embed; v2 or v1 = force one API
COHERE_EMBED_API=auto
# Optional: comma-separated extra model IDs if the primary 404s.
# COHERE_EMBED_FALLBACK_MODELS=
COHERE_GENERATE_MODEL=command-r-plus

# Local model settings (only when USE_LOCAL_MODEL=true)
LOCAL_LLM_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct
LOCAL_EMBED_MODEL_ID=BAAI/bge-m3
LOCAL_DEVICE=cuda